    "custom_css": "/* smaller padding for the whole website */\n\n.container,\n.container-fluid {\n  padding-left: 1rem;\n  padding-right: 1rem;\n}\n\n/* smaller padding for header*/\n\n.header {\n  padding: 0.5rem 0 ;\n}\n\n/* filter categories  */\n\n.posts__tab-label, .posts-ajax__tab-label {\n\tfont-size: 18px\n}\n\n.posts-ajax__row, .posts__categories-wrapper {justify-content: center; }\n\n.posts__tab:hover .posts__tab-label, .posts-ajax__tab:hover .posts-ajax__tab-label, .posts__tab.checked .posts__tab-label, .posts-ajax__tab.checked .posts-ajax__tab-label {color: %#afafaf;}\n\n\n/* blog post card body font size and colors */\n\n.blog-post-type .post-card .post-card__body * {font-size: 18px}\n\n.blog-post-type .post-card:hover .post-card__body {color: #afafaf;}\n\n.blog-post-type .post-card:hover .post-card__body a {color: #afafaf;}\n\n/* portfolio post card body font size and colors */\n\n.portfolio-post-type .post-card .post-card__body {font-size: 18px}\n\n.portfolio-post-type .post-card .post-card__heading {font-size: 18px}\n\n.portfolio-post-type .post-card:hover .post-card__body {color: #afafaf;}\n\n.portfolio-post-type .post-card:hover .post-card__body a {color: #afafaf;}\n\n/* custom thinner separator */\n\n.wp-block-separator {\n  border-width: 1px;\n}\n\n/* blog post card 4 */\n\n.blog-post-card-4 figure {\n  margin-bottom: 0.25rem;\n}\n",
